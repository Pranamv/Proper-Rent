# Shared
APP_ENV=local
APP_VERSION=0.1.0

# Backend
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
DATABASE_URL=postgresql+asyncpg://postgres:password@db.example.supabase.co:5432/postgres
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:
OPENROUTER_API_KEY=replace-with-openrouter-key
LLM_MODEL=openai/gpt-4o-mini
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
RESEND_API_KEY=replace-with-resend-key
RESEND_FROM_EMAIL=Proper Rent <hello@properrent.co.uk>
ADMIN_ALERT_EMAIL=ops@example.com
SYNC_INTERVAL_HOURS=12
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Plausible data-domain. Leave blank in local/test to disable analytics.
NEXT_PUBLIC_ANALYTICS_DOMAIN=
# Reserved for equivalent cookieless providers that need a separate site id.
NEXT_PUBLIC_ANALYTICS_SITE_ID=
# Supabase browser client (auth/session only — data access goes through the API).
# Real values live in frontend/.env.local. The publishable key is safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-with-publishable-key
