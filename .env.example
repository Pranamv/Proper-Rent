# App
APP_ENV=local
APP_VERSION=0.1.0

# Backend: API
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
CONSENT_VERSION=2026-06-13
SYNC_INTERVAL_HOURS=12

# Backend: Database
DATABASE_URL=postgresql+asyncpg://postgres:password@db.example.supabase.co:5432/postgres
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# Backend: Supabase (server-only secrets)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Backend: AI
OPENROUTER_API_KEY=replace-with-openrouter-key
LLM_MODEL=openai/gpt-4o-mini

# Backend: Rate limits
PUBLIC_RATE_LIMIT_ENABLED=true
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_RATE_LIMIT_MAX_REQUESTS=30
LEADS_RATE_LIMIT_MAX_REQUESTS=30
LANDLORDS_RATE_LIMIT_MAX_REQUESTS=30
CHAT_SESSION_MAX_TURNS=50

# Backend: Email
RESEND_API_KEY=replace-with-resend-key
RESEND_FROM_EMAIL=Proper Rent <hello@properrent.co.uk>
ADMIN_ALERT_EMAIL=ops@example.com

# Backend: Meta webhooks
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# Frontend: App URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONSENT_VERSION=2026-06-13

# Frontend: Analytics (leave blank locally to disable)
NEXT_PUBLIC_ANALYTICS_DOMAIN=
NEXT_PUBLIC_ANALYTICS_SITE_ID=

# Frontend: Supabase browser client (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-with-publishable-key
